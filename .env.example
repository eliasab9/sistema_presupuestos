# ─────────────────────────────────────────────────────────────────────────────
# Sistema de Presupuestos — Variables de Entorno
# Copiá este archivo a  .env.local  y completá los valores reales.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ── EMAIL — Gmail SMTP ────────────────────────────────────────────────────────
# Cómo obtener la Contraseña de Aplicación:
#   1. Cuenta Gmail → Seguridad → Verificación en dos pasos (activar)
#   2. Seguridad → Contraseñas de aplicación
#   3. Aplicación: Correo | Dispositivo: Otro → "Presupuestos"
#   4. Copiar la contraseña de 16 caracteres

GMAIL_USER_BEMEC=cotizacionesbemec@gmail.com
GMAIL_PASS_BEMEC=xxxx xxxx xxxx xxxx
GMAIL_REPLY_BEMEC=eagustin@bemec.ar

GMAIL_USER_BAMORE=cotizacionesbamore@gmail.com
GMAIL_PASS_BAMORE=xxxx xxxx xxxx xxxx
GMAIL_REPLY_BAMORE=ventas@bamore.com.ar


# ── GOOGLE DRIVE — Service Account ───────────────────────────────────────────
#
# Este método NO requiere OAuth, ni login del usuario, ni redirect URIs.
# Funciona 100% automático desde el servidor.
#
# PASO 1 — Crear proyecto y habilitar API
# ───────────────────────────────────────
#   1. Ir a https://console.cloud.google.com
#   2. Crear proyecto nuevo (ej: "Presupuestos BEMEC")
#   3. Menú → APIs y servicios → Biblioteca
#   4. Buscar "Google Drive API" → Habilitar
#
# PASO 2 — Crear la Service Account
# ──────────────────────────────────
#   1. Menú → APIs y servicios → Credenciales
#   2. + Crear credenciales → Cuenta de servicio
#   3. Nombre: "presupuestos-drive" → Crear y continuar
#   4. Rol: "Editor" (o "Básico > Editor") → Continuar → Listo
#   5. Click en la cuenta creada → pestaña "Claves"
#   6. Agregar clave → Crear clave nueva → JSON → descargar el archivo
#
# PASO 3 — Compartir las carpetas de Drive
# ─────────────────────────────────────────
#   1. Abrir Google Drive
#   2. Clic derecho en la carpeta raíz de BEMEC → Compartir
#   3. Pegar el email de la service account (termina en @...iam.gserviceaccount.com)
#   4. Rol: "Editor" → Enviar
#   5. Repetir para la carpeta raíz de BAMORE
#
# PASO 4 — Cargar las credenciales en .env.local
# ────────────────────────────────────────────────
#   1. Abrir el archivo JSON descargado con un editor de texto
#   2. Copiar TODO el contenido
#   3. Pegarlo en una sola línea (sin saltos de línea) como valor de la variable
#      Tip: en macOS podés usar:  cat archivo.json | tr -d '\n'
#
# Ejemplo de cómo debe quedar (el valor va entre comillas simples):
# GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...","client_email":"presupuestos-drive@proyecto.iam.gserviceaccount.com",...}'

GOOGLE_SERVICE_ACCOUNT_KEY='{ "type": "service_account", ... }'


# ── URL de la app ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
